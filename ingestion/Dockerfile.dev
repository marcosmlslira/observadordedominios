FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
        libpq-dev \
        gcc \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install dependencies first (cached layer)
COPY pyproject.toml .
RUN pip install --no-cache-dir apscheduler>=3.10 psycopg2-binary polars boto3 requests \
    pydantic-settings pyarrow

# Mount source at /app in dev stack (hot reload via watchdog)
# Editable install happens at container start
CMD ["sh", "-c", "pip install -e . -q && python scheduler.py"]
